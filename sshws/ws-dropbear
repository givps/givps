#!/usr/bin/env python3
import socket
import threading
import select
import signal
import sys
import time
import argparse
from typing import Optional

# Default Configuration
LISTENING_ADDR = "0.0.0.0"
LISTENING_PORT = 8080
PASS = ""  # Set a strong password here, e.g., PASS = "your_secret_password"
BUFLEN = 4096 * 4
IDLE_TIMEOUT = 60  # seconds until connection closes if idle
DEFAULT_TARGET = "127.0.0.1:109"  # Default target if X-Real-Host is not found (usually Dropbear port)

# Standard WebSocket-like handshake response for tunneling clients
RESPONSE_HANDSHAKE = (
    "HTTP/1.1 101 Switching Protocols\r\n"
    "Connection: Upgrade\r\n"  # Added standard header
    "Upgrade: websocket\r\n"   # Added standard header
    "Content-Length: 104857600000\r\n\r\n"
)


class Server(threading.Thread):
    """Manages the listening socket and handles connection threads."""
    def __init__(self, host: str, port: int):
        super().__init__()
        self.running = False
        self.host = host
        self.port = port
        self.threads: list[ConnectionHandler] = []
        self.threadsLock = threading.Lock()
        self.logLock = threading.Lock()
        self.printLog(f":------- PythonProxy -------:")
        self.printLog(f"Listening addr: {self.host}")
        self.printLog(f"Listening port: {self.port}")
        self.printLog(f"Password set: {'Yes' if PASS else 'No (Open Proxy)'}")
        self.printLog(f"Default target: {DEFAULT_TARGET}")
        self.printLog(f":---------------------------:\n")

    def run(self):
        """Main loop to accept incoming connections."""
        self.soc = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.soc.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        self.soc.settimeout(2)
        
        try:
            self.soc.bind((self.host, self.port))
            self.soc.listen(128)
            self.running = True
        except Exception as e:
            self.printLog(f"❌ ERROR: Failed to bind socket on {self.host}:{self.port}. {e}")
            self.running = False
            return

        try:
            while self.running:
                try:
                    c, addr = self.soc.accept()
                    c.setblocking(True)
                except socket.timeout:
                    continue
                except socket.error:
                    continue 

                conn = ConnectionHandler(c, self, addr)
                conn.start()
                self.addConn(conn)
        finally:
            self.running = False
            self.soc.close()
            self.printLog("Server socket closed.")

    def printLog(self, log: str):
        """Thread-safe logging."""
        with self.logLock:
            print(log, flush=True)

    def addConn(self, conn: 'ConnectionHandler'):
        """Adds a connection thread to the active list."""
        with self.threadsLock:
            if self.running:
                self.threads.append(conn)

    def removeConn(self, conn: 'ConnectionHandler'):
        """Removes a connection thread from the active list."""
        with self.threadsLock:
            if conn in self.threads:
                self.threads.remove(conn)

    def close(self):
        """Stops the server and closes all active connections."""
        self.running = False
        self.printLog("Attempting to close all connections...")
        with self.threadsLock:
            for c in list(self.threads):
                c.close()
            self.threads.clear()
        # Close the main listening socket to break the run loop
        try:
            self.soc.close()
        except Exception:
            pass


class ConnectionHandler(threading.Thread):
    """Handles data forwarding for a single client-target pair."""
    def __init__(self, socClient: socket.socket, server: Server, addr: tuple):
        super().__init__()
        self.clientClosed = False
        self.targetClosed = True
        self.client = socClient
        self.target: Optional[socket.socket] = None
        self.client_buffer = b""
        self.server = server
        self.addr = addr
        self.log = f"[{addr[0]}:{addr[1]}]"

    def close(self):
        """Safely closes both client and target sockets."""
        try:
            if not self.clientClosed:
                self.client.shutdown(socket.SHUT_RDWR)
                self.client.close()
        except Exception:
            pass
        finally:
            self.clientClosed = True

        try:
            if self.target and not self.targetClosed:
                self.target.shutdown(socket.SHUT_RDWR)
                self.target.close()
        except Exception:
            pass
        finally:
            self.targetClosed = True

    def run(self):
        """Processes handshake and starts tunneling."""
        try:
            # 1. Receive initial request
            self.client.settimeout(10) # Set short timeout for handshake
            self.client_buffer = self.client.recv(BUFLEN)
            self.client.settimeout(None) # Remove timeout for data transfer
            if not self.client_buffer:
                return

            # 2. Extract headers
            hostPort = self.findHeader(self.client_buffer, "X-Real-Host")
            passwd = self.findHeader(self.client_buffer, "X-Pass")
            split = self.findHeader(self.client_buffer, "X-Split")

            if split:
                # Consume extra data chunk if X-Split is present
                self.client.recv(BUFLEN)

            # 3. Validation and connection logic
            if not hostPort:
                hostPort = DEFAULT_TARGET
                self.server.printLog(f"{self.log} - WARN: No X-Real-Host, using default: {DEFAULT_TARGET}")
            
            # Authentication check
            if PASS:
                if passwd == PASS:
                    self.method_CONNECT(hostPort)
                else:
                    self.server.printLog(f"{self.log} - REJECTED: WrongPass")
                    self.client.sendall(b"HTTP/1.1 400 WrongPass!\r\n\r\n")
            elif hostPort.startswith(("127.0.0.1", "localhost")):
                 # If no password is set, restrict connections to local addresses only
                 self.method_CONNECT(hostPort)
            else:
                 # If no password is set AND target is external -> REJECT
                 self.server.printLog(f"{self.log} - REJECTED: Forbidden (No PASS set)")
                 self.client.sendall(b"HTTP/1.1 403 Forbidden!\r\n\r\n")

        except Exception as e:
            self.server.printLog(f"{self.log} - ERROR: {e}")
        finally:
            self.close()
            self.server.removeConn(self)

    def findHeader(self, head: bytes, header: str) -> str:
        """Finds and extracts the value of a custom header."""
        try:
            # Decode using standard ASCII and ignore errors for robustness
            head_str = head.decode("ascii", errors="ignore")
            marker = f"{header}: "
            idx = head_str.find(marker)
            if idx == -1:
                return ""
            
            # Extract the value up to the next CRLF (\r\n)
            value = head_str[idx + len(marker):].split("\r\n", 1)[0]
            return value.strip()
        except Exception:
            return ""

    def connect_target(self, host_port: str):
        """Establishes connection to the target host:port."""
        if ":" in host_port:
            host, p = host_port.split(":", 1)
            port = int(p)
        else:
            host = host_port
            port = int(DEFAULT_TARGET.split(":")[1]) # Use default target port

        self.target = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.targetClosed = False
        self.target.settimeout(10) # Set connection timeout
        try:
            self.target.connect((host, port))
            self.target.settimeout(None) # Remove timeout after successful connect
            self.server.printLog(f"{self.log} - Connected to: {host}:{port}")
        except Exception as e:
            self.server.printLog(f"{self.log} - FAILED to connect to {host}:{port}. {e}")
            raise # Re-raise exception to be caught by run()

    def method_CONNECT(self, path: str):
        """Sends handshake response and starts bidirectional data transfer."""
        self.connect_target(path)
        
        # Send the successful handshake response
        self.client.sendall(RESPONSE_HANDSHAKE.encode('ascii'))
        self.client_buffer = b""
        
        # Start data tunneling
        self.doCONNECT()

    def doCONNECT(self):
        """Bidirectional data forwarding using select.select."""
        if not self.target: return

        socs = [self.client, self.target]
        last_activity = time.time()
        
        while time.time() - last_activity < IDLE_TIMEOUT:
            # Check for data readiness on both sockets with a short timeout
            rlist, _, err = select.select(socs, [], socs, 1) # Wait max 1 second
            
            if err:
                self.server.printLog(f"{self.log} - Socket error detected.")
                break
            
            if rlist:
                # Data is ready on one or both sockets
                for in_ in rlist:
                    try:
                        data = in_.recv(BUFLEN)
                        if not data:
                            self.server.printLog(f"{self.log} - Connection closed by peer.")
                            return
                            
                        # Forward data
                        if in_ is self.target:
                            self.client.sendall(data)
                        else:
                            self.target.sendall(data)
                        
                        # Reset activity timer
                        last_activity = time.time()
                        
                    except Exception as e:
                        self.server.printLog(f"{self.log} - Tunneling failed: {e}")
                        return
            
            # If rlist is empty, select timed out (no data, but no error), loop continues to check IDLE_TIMEOUT
            
        self.server.printLog(f"{self.log} - Connection timed out after {IDLE_TIMEOUT}s of inactivity.")


def main():
    """Main function to parse arguments and start the server."""
    parser = argparse.ArgumentParser(description="Simple Python WebSocket Proxy for SSH/VPN Tunnels (v1.7)")
    parser.add_argument("-b", "--bind", default=LISTENING_ADDR, help=f"Listening address (default {LISTENING_ADDR})")
    parser.add_argument("-p", "--port", type=int, default=LISTENING_PORT, help=f"Listening port (default {LISTENING_PORT})")
    args = parser.parse_args()

    server = Server(args.bind, args.port)
    server.start()
    
    # Handle OS signals for graceful shutdown
    def signal_handler(sig, frame):
        print("\n[Signal Received] Stopping server gracefully...")
        server.close()
        sys.exit(0)

    signal.signal(signal.SIGINT, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)

    try:
        # Keep the main thread alive until a signal is received
        while True:
            time.sleep(1)
    except Exception:
        pass
    finally:
        server.close()


if __name__ == "__main__":
    main()